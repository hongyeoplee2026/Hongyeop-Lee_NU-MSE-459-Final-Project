ient import MPRester\n","from pymatgen.core import Composition, Element\n","\n","drive.mount(\"/content/drive\")\n","\n","API_KEY = getpass(\"JuAfKAicxX9QQ8dXZw6GdM4vC5aPp8V9\")"]},{"cell_type":"code","source":["# ============================================================\n","# Cell 2 — Define save paths\n","# ============================================================\n","\n","SAVE_DIR = \"/content/drive/MyDrive/459/Project/ABX_Composition_Features\"\n","os.makedirs(SAVE_DIR, exist_ok=True)\n","\n","RAW_PICKLE_PATH = os.path.join(SAVE_DIR, \"mp_perovskite_raw_docs.pkl\")\n","FEATURE_PICKLE_PATH = os.path.join(SAVE_DIR, \"mp_abx3_site_composition_features.pkl\")\n","FEATURE_CSV_PATH = os.path.join(SAVE_DIR, \"mp_abx3_site_composition_features.csv\")\n","\n","print(\"Save directory:\")\n","print(SAVE_DIR)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"I9VUEiZRCcFO","executionInfo":{"status":"ok","timestamp":1780634308745,"user_tz":300,"elapsed":44,"user":{"displayName":"Hongyeop Lee","userId":"01015378352603804831"}},"outputId":"86c87f90-d2ae-47af-effc-ad2d10e05c33"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Save directory:\n","/content/drive/MyDrive/459/Project/ABX_Composition_Features\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# Cell 3 — Pull perovskite-described materials from Materials Project\n","# Fixed: save serializable dictionaries, not MPDataDoc objects\n","# ============================================================\n","\n","FIELDS = [\n","    \"material_id\",\n","    \"formula_pretty\",\n","    \"composition\",\n","    \"band_gap\",\n","    \"energy_above_hull\",\n","    \"formation_energy_per_atom\",\n","    \"is_stable\",\n","    \"theoretical\",\n","    \"is_metal\",\n","    \"total_magnetization\",\n","]\n","\n","if os.path.exists(RAW_PICKLE_PATH):\n","    print(\"Raw Materials Project data already exists. Loading...\")\n","    raw_docs = pd.read_pickle(RAW_PICKLE_PATH)\n","    print(f\"Loaded {len(raw_docs)} raw document dictionaries.\")\n","\n","else:\n","    print(\"Searching Robocrystallographer for perovskite-described materials...\")\n","\n","    with MPRester(API_KEY) as mpr:\n","        perov_docs = mpr.materials.robocrys.search(\n","            keywords=[\"perovskite\"]\n","        )\n","\n","    perov_ids = [str(doc.material_id) for doc in perov_docs]\n","\n","    print(f\"Found {len(perov_ids)} perovskite-described entries.\")\n","\n","    print(\"Fetching summary data for those entries...\")\n","\n","    docs = []\n","    CHUNK = 1000\n","\n","    with MPRester(API_KEY) as mpr:\n","        for i in range(0, len(perov_ids), CHUNK):\n","            batch_ids = perov_ids[i:i + CHUNK]\n","\n","            batch = mpr.materials.summary.search(\n","                material_ids=batch_ids,\n","                fields=FIELDS\n","            )\n","\n","            docs.extend(batch)\n","            print(f\"Fetched {len(docs)} / {len(perov_ids)}\")\n","\n","    # Convert MPDataDoc objects to normal dictionaries before saving\n","    raw_docs = []\n","\n","    for d in docs:\n","        raw_docs.append({\n","            \"material_id\": str(d.material_id),\n","            \"formula_pretty\": d.formula_pretty,\n","            \"composition\": d.composition,\n","            \"band_gap\": d.band_gap,\n","            \"energy_above_hull\": d.energy_above_hull,\n","            \"formation_energy_per_atom\": d.formation_energy_per_atom,\n","            \"is_stable\": d.is_stable,\n","            \"theoretical\": d.theoretical,\n","            \"is_metal\": d.is_metal,\n","            \"total_magnetization\": d.total_magnetization,\n","        })\n","\n","    pd.to_pickle(raw_docs, RAW_PICKLE_PATH)\n","\n","    print(f\"Saved raw document dictionaries to:\\n{RAW_PICKLE_PATH}\")\n","\n","print(\"Total raw docs:\", len(raw_docs))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","heigh